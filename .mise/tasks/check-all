#!/usr/bin/env bash
# mise task: check-all
# Run all checks: format, clippy, deny, test
set -euo pipefail

echo "=== cargo fmt (check) ==="
cargo fmt --check

echo "=== cargo clippy ==="
cargo clippy --all-targets --all-features

echo "=== cargo check ==="
cargo check --all-targets --all-features

echo "=== cargo test ==="
cargo test --all-targets --all-features

echo "All checks passed."
