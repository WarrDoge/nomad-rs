#!/usr/bin/env nu
# mise task: check-all
# Run all checks: format, clippy, deny, test

print "=== cargo fmt (check) ==="
cargo fmt --check

print "=== cargo clippy ==="
cargo clippy --all-targets --all-features

print "=== cargo check ==="
cargo check --all-targets --all-features

print "=== cargo test ==="
cargo test --all-targets --all-features

print "All checks passed."
